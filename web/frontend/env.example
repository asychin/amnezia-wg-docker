# AmneziaWG Web Frontend Configuration

# Development
NODE_ENV=development
VITE_APP_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost/api/v1
VITE_WS_BASE_URL=ws://localhost/ws

# Application Settings
VITE_APP_NAME=AmneziaWG Web Interface
VITE_APP_VERSION=1.0.0

# Connection String Settings
VITE_CONNECTION_PREFIX=awgwc://
VITE_DEFAULT_SERVER_NAME=AmneziaWG Server

# UI Settings
VITE_THEME_DEFAULT=light
VITE_SIDEBAR_COLLAPSED=false
VITE_AUTO_REFRESH_INTERVAL=10000

# Debug
VITE_DEBUG=false
VITE_LOG_LEVEL=info
