# ============================================================================
# AMNEZIAWG WEB FRONTEND CONFIGURATION
# ============================================================================

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Режим Node.js: development, production
NODE_ENV=development

# Базовый URL для API запросов (используется в production)
# В development Vite автоматически проксирует /api на localhost:8080
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Таймаут для API запросов (миллисекунды)
VITE_API_TIMEOUT=10000

# WebSocket URL для real-time логов
VITE_WS_URL=ws://localhost:8080/api/v1/logs/stream

# ============================================================================
# UI SETTINGS
# ============================================================================

# Название приложения (отображается в заголовке)
VITE_APP_TITLE=AmneziaWG Management

# Версия приложения
VITE_APP_VERSION=1.0.0

# Автообновление данных (секунды)
VITE_REFRESH_INTERVAL=30

# ============================================================================
# THEMING
# ============================================================================

# Тема по умолчанию: light, dark, system
VITE_DEFAULT_THEME=system

# Включить переключатель темы
VITE_ENABLE_THEME_TOGGLE=true

# ============================================================================
# FEATURES
# ============================================================================

# Включить real-time мониторинг
VITE_ENABLE_REALTIME=true

# Включить управление сервером (start/stop/restart)
VITE_ENABLE_SERVER_CONTROL=true

# Включить экспорт конфигураций
VITE_ENABLE_CONFIG_EXPORT=true

# Максимальное количество строк логов для отображения
VITE_MAX_LOG_LINES=1000

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Включить debug режим (дополнительные логи в консоли)
VITE_DEBUG=false

# Показывать mock данные если API недоступен
VITE_USE_MOCK_DATA=false
