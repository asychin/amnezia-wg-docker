# AmneziaWG Web Backend Configuration

# Server Configuration
SERVER_ADDRESS=:8080
SERVER_ENVIRONMENT=development

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-32chars-minimum
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=24h

# Database Configuration (SQLite)
DATABASE_URL=file:./data/amneziawg.db?cache=shared&mode=rwc

# VPN Server Integration
VPN_CONTAINER_NAME=amneziawg-server
VPN_DOCKER_SOCKET=/var/run/docker.sock
VPN_PROJECT_PATH=/app/amnezia-wg-docker

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1h

# Connection String Settings
CONNECTION_DEFAULT_TTL=720h
SERVER_DEFAULT_LOCATION=Unknown
API_ENDPOINT_HOST=localhost:80
API_ENDPOINT_PROTOCOL=http
