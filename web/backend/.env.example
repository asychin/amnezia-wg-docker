# ============================================================================
# AMNEZIAWG WEB API CONFIGURATION
# ============================================================================

# ============================================================================
# ОСНОВНЫЕ НАСТРОЙКИ СЕРВЕРА
# ============================================================================

# Окружение: development, production
ENVIRONMENT=development

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# Адрес и порт для API сервера
SERVER_ADDRESS=:8080

# Таймауты HTTP сервера
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s

# ============================================================================
# НАСТРОЙКИ CORS
# ============================================================================

# Разрешенные домены для CORS (разделенные запятой)
# В production укажите конкретные домены
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# ============================================================================
# ИНТЕГРАЦИЯ С AMNEZIAWG
# ============================================================================

# Путь к конфигурационным файлам AmneziaWG
AWG_CONFIG_PATH=/app/config

# Путь к файлам клиентов
AWG_CLIENTS_PATH=/app/clients

# Путь к скриптам управления
AWG_SCRIPTS_PATH=/app/scripts

# Команда для выполнения make операций
AWG_MAKE_COMMAND=make

# Имя Docker контейнера с AmneziaWG сервером
AWG_SERVICE_NAME=amneziawg-server
